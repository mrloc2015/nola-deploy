{
    "name": "nola/deploy",
    "description": "High-performance Magento 2 deployment CLI — optimizes di:compile, static-content:deploy with change detection, parallelism, and zero-downtime switching.",
    "type": "library",
    "license": "MIT",
    "bin": ["bin/nola-deploy"],
    "require": {
        "php": "^8.1",
        "symfony/console": "^6.0|^7.0",
        "symfony/process": "^6.0|^7.0",
        "symfony/yaml": "^6.0|^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Nola\\Deploy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Nola\\Deploy\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable"
}
